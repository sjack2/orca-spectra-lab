# ============================================================
# ORCA pipeline — output data (cluster-only, never committed)
# ============================================================

# Per-molecule output trees (all pipeline stages)
pna/
ephedrine/
methyloxirane/

# Generic catch-all for any other molecule directories
# (matches any dir that looks like a pipeline output tree)
*/01_gas_opt/
*/02_conf_search/
*/03_solvent_opt/
*/04_boltzmann/
*/05_ecd/
*/05_vcd/
*/06_spectra/

# Scratch / pre-computed XYZ inputs (live on cluster only)
pre_xyz/

# ORCA scratch and temp files
*.tmp
*.gbw
*.densities
*.ges
*.prop
*.opt
slurm-*.out
slurm-*.err

# Python cache
__pycache__/
*.pyc
